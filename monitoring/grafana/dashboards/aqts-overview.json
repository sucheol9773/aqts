{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "System Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "aqts_system_status",
          "legendFormat": "System"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNHEALTHY" }, "0.5": { "text": "DEGRADED" }, "1": { "text": "HEALTHY" } } }
          ]
        }
      }
    },
    {
      "title": "Component Health",
      "type": "table",
      "gridPos": { "h": 4, "w": 10, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "aqts_component_health",
          "legendFormat": "{{component}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "title": "Requests In Progress",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "sum(aqts_http_requests_in_progress)",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(aqts_http_requests_total[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "title": "Request Latency P95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aqts_http_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "title": "Circuit Breaker States",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "aqts_circuit_breaker_state",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED" }, "0.5": { "text": "HALF_OPEN" }, "1": { "text": "OPEN" } } }
          ]
        }
      }
    },
    {
      "title": "Portfolio Value (KRW)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "aqts_portfolio_value_krw",
          "legendFormat": "Portfolio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyKRW"
        }
      }
    },
    {
      "title": "Orders Executed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(aqts_orders_total[1h])) by (side)",
          "legendFormat": "{{side}}"
        }
      ]
    },
    {
      "title": "Daily Return %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "aqts_daily_return_pct",
          "legendFormat": "Daily Return"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -1 },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "title": "Ensemble Confidence",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "aqts_ensemble_confidence",
          "legendFormat": "Confidence"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "title": "Data Collection Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aqts_data_collection_duration_seconds_bucket[5m])) by (le, source))",
          "legendFormat": "{{source}} P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(aqts_http_requests_total{status_code=~\"5..\"}[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}} 5xx"
        }
      ]
    },
    {
      "title": "KIS API Degraded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "aqts_kis_degraded",
          "legendFormat": "KIS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "HEALTHY" }, "1": { "text": "DEGRADED" } } }
          ]
        }
      }
    },
    {
      "title": "KIS Recovery Success Ratio (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "targets": [
        {
          "expr": "aqts_kis_recovery_success_total / clamp_min(aqts_kis_recovery_attempts_total, 1)",
          "legendFormat": "success ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "title": "KIS Recovery Attempts (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "rate(aqts_kis_recovery_attempts_total[5m])",
          "legendFormat": "attempts/s"
        },
        {
          "expr": "rate(aqts_kis_recovery_success_total[5m])",
          "legendFormat": "success/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "title": "KIS Recovery Totals",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "aqts_kis_recovery_attempts_total",
          "legendFormat": "attempts_total"
        },
        {
          "expr": "aqts_kis_recovery_success_total",
          "legendFormat": "success_total"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["aqts", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "AQTS System Overview",
  "uid": "aqts-overview"
}
