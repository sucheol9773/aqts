global:
  scrape_interval: 15s
  evaluation_interval: 15s

# ── Alertmanager 연동 ──
alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

# ── 알림 규칙 파일 ──
# Prometheus 는 rule_files 의 상대 경로를 config 파일 디렉터리 기준으로
# 해석한다. 본 파일은 entrypoint 에서 sed 렌더링되어 `/tmp/prometheus.yml`
# 로 실행되므로, 상대 경로 "rules/*.yml" 는 `/tmp/rules/*.yml` 를 가리켜
# 존재하지 않는다 (빈 glob 은 에러가 아니므로 규칙이 조용히 0개 로드된다).
# 컨테이너 내 실 마운트 위치인 `/etc/prometheus/rules/*.yml` 를 절대 경로로
# 명시하여 렌더링 위치와 무관하게 규칙을 로드한다. CLAUDE.md 의 "경로 불
# 일치 silent miss" 회귀 방지(2026-04-16).
rule_files:
  - "/etc/prometheus/rules/*.yml"

scrape_configs:
  - job_name: "aqts-backend"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["backend:8000"]
        labels:
          service: "aqts-backend"

  # 카나리 배포 시 stable/canary 개별 스크래핑
  - job_name: "aqts-backend-stable"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["backend-stable:8000"]
        labels:
          service: "aqts-backend"
          role: "stable"
    # 카나리 미사용 시 연결 실패해도 무시됨

  - job_name: "aqts-backend-canary"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["backend-canary:8000"]
        labels:
          service: "aqts-backend"
          role: "canary"

  # 호스트 VM 메트릭 (디스크/CPU/메모리/네트워크).
  # docker-compose.yml 의 node-exporter service 가 /host 에 rootfs 를 read-only
  # 로 마운트하여 노출한다. host 라벨은 환경변수 HOST_LABEL 로 주입되어
  # entrypoint 에서 sed 로 치환된다 (alertmanager 와 동일 패턴).
  # 단일 VM 환경에서는 기본값 aqts-server 로 충분하고, 호스트가 늘어나면
  # compose 환경변수만 바꿔 멀티 호스트 식별이 가능하다.
  - job_name: "aqts-node-exporter"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["node-exporter:9100"]
        labels:
          service: "aqts-host"
          host: "${HOST_LABEL}"

  # PostgreSQL 메트릭 (pg_stat_archiver / pg_stat_replication / pg_settings).
  # docker-compose.yml 의 postgres-exporter service 가 9187 포트로 노출한다.
  # OPS-028 (postgres-wal-archive-permission-2026-04-26.md) §4.1 monitoring
  # 격차 (archive 실패 19일 silent miss) 영구 해소의 source-of-truth 매트릭.
  - job_name: "aqts-postgres-exporter"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["postgres-exporter:9187"]
        labels:
          service: "aqts-postgres"
          host: "${HOST_LABEL}"

  # Prometheus 자체 self-scrape (self-observability).
  # 본 모니터링 시스템의 self-monitoring 표준 패턴 — 자체 매트릭
  # (prometheus_config_last_reload_successful, prometheus_rule_evaluation_*,
  # prometheus_tsdb_*, prometheus_target_*) 을 노출하여 config reload 실패,
  # rule evaluation 실패, scrape pool 이상 등을 외부에서 관측 가능하게 한다.
  # OPS-030 (infrastructure-backfill-audit-2026-04-27.md) §2.1 GAP 항목 P1.
  # 자기 참조라 `absent(up{job="aqts-prometheus"}==1)` 패턴은 의미가 없으나
  # config_reload_failures 같은 능동 매트릭은 Alertmanager 채널로 전파 가능.
  - job_name: "aqts-prometheus"
    metrics_path: "/metrics"
    static_configs:
      - targets: ["prometheus:9090"]
        labels:
          service: "aqts-prometheus"
          host: "${HOST_LABEL}"
