# ═══════════════════════════════════════════════════════════════════════════════
# AQTS (AI Quant Trade System) 환경변수 설정 파일
#
# 사용 방법:
# 1. 이 파일을 복사하여 .env 파일을 생성합니다:
#    cp .env.example .env
# 2. 귀하의 실제 API 키와 계좌 정보를 입력합니다.
# 3. .env 파일은 .gitignore에 포함되어 버전 관리에서 자동 제외됩니다.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 애플리케이션 기본 설정
# ─────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# 한국투자증권 OpenAPI 설정
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 거래 모드 선택
# ─────────────────────────────────────────────────────────────────────────────
# 옵션: LIVE (실전 거래), DEMO (모의 거래), BACKTEST (백테스트 전용, API 호출 없음)
# ⚠️ 주의: LIVE 모드에서는 실제 자금이 투입되므로 신중하게 선택하세요.
KIS_TRADING_MODE=DEMO

# ─────────────────────────────────────────────────────────────────────────────
# 한국투자증권 실전 거래 (LIVE TRADING)
# ─────────────────────────────────────────────────────────────────────────────
KIS_LIVE_APP_KEY=your_live_app_key_here
KIS_LIVE_APP_SECRET=your_live_app_secret_here
KIS_LIVE_ACCOUNT_NO=your_live_account_number_here
KIS_LIVE_ACCOUNT_PROD=01
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443
# ⚠️ 보안 주의: KIS WebSocket은 현재 ws:// (비암호화)만 공식 지원합니다.
# 운영(ENVIRONMENT=production) + LIVE 모드에서는 ws:// 사용 시 부팅이 차단됩니다.
# KIS가 wss://를 지원하면 즉시 전환하세요.
# ws://를 임시 허용하려면 아래 예외 설정 3개를 모두 설정해야 합니다.
KIS_LIVE_WEBSOCKET_URL=ws://ops.koreainvestment.com:21000

# ─────────────────────────────────────────────────────────────────────────────
# 한국투자증권 모의 거래 (PAPER TRADING / SIMULATION)
# ─────────────────────────────────────────────────────────────────────────────
KIS_DEMO_APP_KEY=your_demo_app_key_here
KIS_DEMO_APP_SECRET=your_demo_app_secret_here
KIS_DEMO_ACCOUNT_NO=your_demo_account_number_here
KIS_DEMO_ACCOUNT_PROD=01
KIS_DEMO_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_DEMO_WEBSOCKET_URL=ws://ops.koreainvestment.com:31000

# ─────────────────────────────────────────────────────────────────────────────
# 한국투자증권 API 공통 설정
# ─────────────────────────────────────────────────────────────────────────────
KIS_HTS_ID=
KIS_TOKEN_REFRESH_INTERVAL=3600
KIS_API_TIMEOUT=10
# 일반 REST 호출(시세/주문 조회 등)의 재시도 횟수.
KIS_API_RETRY_COUNT=3
# 토큰 발급 전용 재시도 정책 (위 KIS_API_RETRY_COUNT 와 의미가 다름).
# 토큰 획득은 지수 백오프가 필요하므로 별도 파라미터로 분리되어 있다.
# KISSettings.token_retry_count / token_retry_max_wait 로 read.
KIS_TOKEN_RETRY_COUNT=5
KIS_TOKEN_RETRY_MAX_WAIT=60
# 장애 복구 쿨다운: KIS API 연속 실패 후 재접속 재시도 간격 (초).
# backend/main.py:242 에서 직접 read.
KIS_RECOVERY_COOLDOWN_SECONDS=75
# 기동 jitter 상한: 다중 컨테이너 동시 기동 시 KIS 토큰 발급이 몰리지 않도록
# 0 ~ 이 값 사이 랜덤 지연 (초). backend/main.py:269 에서 직접 read.
KIS_STARTUP_JITTER_MAX_SECONDS=15.0

# ─────────────────────────────────────────────────────────────────────────────
# WebSocket 보안 예외 (운영+LIVE에서 ws:// 임시 허용 시 3개 모두 필수)
# ─────────────────────────────────────────────────────────────────────────────
# 기본값(아래 3개) 에서는 ENVIRONMENT=production + KIS_TRADING_MODE=LIVE + ws://
# 조합의 부팅이 차단된다. 예외가 필요하면 아래 3개를 모두 실제 값으로 설정하고
# docs/security/kis-websocket-security.md §3.2 / §7 절차를 따른다.
# - INSECURE_ALLOW 는 "true"/"false" 표준 표기만 허용 (env_bool 이 아닌 전용 파서).
# - EXCEPTION_TICKET 은 변경 관리 시스템의 실재 티켓 ID (예: CHG-2026-0042).
# - EXCEPTION_EXPIRES_AT 은 YYYY-MM-DD, 당일 23:59:59 UTC 까지 유효. 경과 시 부팅 차단.
KIS_WS_INSECURE_ALLOW=false
KIS_WS_EXCEPTION_TICKET=
KIS_WS_EXCEPTION_EXPIRES_AT=

# ═══════════════════════════════════════════════════════════════════════════════
# Anthropic Claude API 설정 (AI 기반 분석)
# ═══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# 기본 모델: 비용 효율 (감성 분석, 일반 뉴스 요약 등)
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001
# 고급 모델: 복잡한 분석 (거시경제 분석, 투자 의견 생성 등)
ANTHROPIC_ADVANCED_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_TIMEOUT=30
ANTHROPIC_CACHE_TTL=14400

# ═══════════════════════════════════════════════════════════════════════════════
# 데이터베이스 설정
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL / TimescaleDB
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aqts
DB_USER=aqts_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=aqts
MONGO_USER=aqts_user
MONGO_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password_here
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════════════════════
# 외부 데이터 제공자 API
# ═══════════════════════════════════════════════════════════════════════════════
DART_API_KEY=your_dart_api_key_here
FRED_API_KEY=your_fred_api_key_here
ECOS_API_KEY=your_ecos_api_key_here
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=AQTS/1.0

# ═══════════════════════════════════════════════════════════════════════════════
# 알림 설정
# ═══════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# 옵션: ALL, IMPORTANT, ERROR
TELEGRAM_ALERT_LEVEL=IMPORTANT

# 이메일 알림 (선택사항 - 향후 확장용)
# SMTP_SERVER=your_smtp_server_here
# SMTP_PORT=587
# SMTP_USERNAME=your_email@example.com
# SMTP_PASSWORD=your_smtp_password_here
# ALERT_EMAIL=your_alert_email@example.com

# ═══════════════════════════════════════════════════════════════════════════════
# 대시보드 설정
# ═══════════════════════════════════════════════════════════════════════════════
BACKEND_PORT=8000
DASHBOARD_SECRET_KEY=your_jwt_secret_key_here
# JWT 키 롤링: 이전(구) 시크릿. 발급된 토큰의 검증 용도로 일시 유지한다.
# DashboardSettings.previous_secret_key 로 read. 롤링 완료 후 공란으로 회수.
DASHBOARD_PREVIOUS_SECRET_KEY=
# 액세스/리프레시 토큰 만료 (단위: 시간 / 일)
DASHBOARD_ACCESS_TOKEN_EXPIRE_HOURS=1
DASHBOARD_REFRESH_TOKEN_EXPIRE_DAYS=14
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me_strong_password
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# 토큰 폐기 저장소: 운영=redis, 테스트=memory (미설정 시 부팅 실패)
AQTS_REVOCATION_BACKEND=redis

# ─────────────────────────────────────────────────────────────────────────────
# 알림 파이프라인 (재시도 루프)
# ─────────────────────────────────────────────────────────────────────────────
# 알림 전송 실패 건의 재시도 루프 활성화. backend/main.py:166 에서 env_bool 로 read.
# false 로 내리면 일회성 dispatch 만 수행 (재시도 없음).
ALERT_RETRY_LOOP_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# Scheduler heartbeat (프로세스 생존 관측)
# ─────────────────────────────────────────────────────────────────────────────
# scheduler 프로세스가 주기적으로 갱신하는 파일 경로.
# core/scheduler_heartbeat.py:28 에서 read. 컨테이너 내부 tmpfs 경로를 기본으로.
SCHEDULER_HEARTBEAT_PATH=/tmp/scheduler.heartbeat
# heartbeat 가 이 값(초) 이상 갱신되지 않으면 stale 로 판정하여 healthcheck 실패.
SCHEDULER_HEARTBEAT_STALE_SECONDS=180

# ─────────────────────────────────────────────────────────────────────────────
# OpenTelemetry (분산 추적)
# ─────────────────────────────────────────────────────────────────────────────
# true 로 설정 시 FastAPI/HTTP/DB 호출 span 을 OTEL exporter 로 송출.
# core/monitoring/tracing.py:24 에서 env_bool 로 read. 기본 비활성.
OTEL_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# 거래 실행 및 리스크 관리 설정 (단위: 원)
# ═══════════════════════════════════════════════════════════════════════════════
INITIAL_CAPITAL_KRW=50000000
DAILY_LOSS_LIMIT_KRW=5000000
MAX_ORDER_AMOUNT_KRW=10000000
MAX_POSITIONS=20
MAX_POSITION_WEIGHT=0.20
MAX_SECTOR_WEIGHT=0.40
CONSECUTIVE_LOSS_LIMIT=5
MAX_DRAWDOWN=0.20
STOP_LOSS_PERCENT=-0.10
COMMISSION_KR=0.00015
COMMISSION_US=0.001

# ═══════════════════════════════════════════════════════════════════════════════
# 컨테이너 이미지 레지스트리 (필수)
# ═══════════════════════════════════════════════════════════════════════════════
# docker-compose.yml 의 backend/scheduler 서비스는 ghcr.io/${IMAGE_NAMESPACE}/
# aqts-backend:${IMAGE_TAG:-latest} 이미지를 참조한다. IMAGE_NAMESPACE 가 비어
# 있으면 `docker compose` 명령이 parse 단계에서 전체 중단되므로 (특정 서비스만
# 타겟한 명령도 포함), 운영 서버 .env 에는 반드시 값이 설정되어 있어야 한다.
#
# 값: GitHub 저장소 owner 의 소문자 username (예: sucheol9773).
# 참고: docs/operations/docker-setup-guide.md §컨테이너 레지스트리
IMAGE_NAMESPACE=your_github_owner_lowercase
# IMAGE_TAG: 미지정 시 docker-compose.yml 의 :- 기본값 (latest) 로 폴백한다.
# ⚠️ 운영(ENVIRONMENT=production) 에서는 latest 폴백을 사용하지 말고, CI 가
# 배포한 커밋의 sha-<digest> 태그 (예: sha-e7b5187) 로 명시 pin 한다. 그래야
# cosign verify + SBOM attestation 과 digest 가 일치해 공급망 Wiring Rule
# (docs/security/supply-chain-policy.md §7) 이 보장된다.
IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════════════════════════
# 모니터링 (Grafana / Prometheus / Alertmanager / Jaeger)
# ═══════════════════════════════════════════════════════════════════════════════
# Grafana 관리자 계정/비밀번호. PASSWORD 는 fallback 없음, 반드시 설정 필요.
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_strong_grafana_password
# 호스트 포트 바인딩 (컨테이너 내부 포트는 고정).
# docker-compose.yml 에서 ${VAR:-default} 로 read — 미설정 시 아래 기본값 사용.
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
JAEGER_UI_PORT=16686
# node-exporter: 호스트 VM 디스크/CPU/메모리/네트워크 메트릭. 127.0.0.1 바인드이며
# Prometheus 는 compose 네트워크 DNS(node-exporter:9100) 로 접근한다.
NODE_EXPORTER_PORT=9100

# Prometheus 가 호스트 메트릭에 부착하는 host 라벨. aqts_host_system 알림
# 규칙이 {{ $labels.host }} 로 호스트를 식별하는 근거이며, 멀티 호스트로
# 확장될 경우 각 서버별로 다르게 설정한다. prometheus.yml.tmpl 의
# ${HOST_LABEL} 플레이스홀더가 prometheus 컨테이너 entrypoint 의 sed 로
# 치환된다 (alertmanager TELEGRAM_* 치환과 동일 패턴).
HOST_LABEL=aqts-server

# ═══════════════════════════════════════════════════════════════════════════════
# DB 백업 (db-backup 서비스)
# ═══════════════════════════════════════════════════════════════════════════════
# 백업 주기(시간) / 로컬 보관 기간(일). docker-compose.yml 의 db-backup 에서 read.
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
# GCS(Google Cloud Storage) 업로드 버킷. 공란이면 로컬 보관만 수행.
# 값이 설정되면 db-backup 서비스가 gsutil 로 원격 업로드까지 수행한다.
GCS_BACKUP_BUCKET=

# ═══════════════════════════════════════════════════════════════════════════════
# 고급 설정 (선택사항)
# ═══════════════════════════════════════════════════════════════════════════════
# uvicorn 워커 수 (백엔드 API 서버).
# 참고: 현재 backend/Dockerfile 의 CMD 가 --workers 1 로 하드코딩되어 있어
# 이 값은 즉시 반영되지 않는다. compose command override 또는 Dockerfile
# CMD 수정으로 배선하는 작업은 별건 스코프 (환경 튜닝 PR).
WORKER_COUNT=4

# ═══════════════════════════════════════════════════════════════════════════════
# 보안 및 주의사항
# ═══════════════════════════════════════════════════════════════════════════════
#
# 🔐 보안 체크리스트:
# - [ ] .env 파일을 절대로 Git에 커밋하지 마세요.
# - [ ] API 키와 시크릿을 정기적으로 갱신하세요.
# - [ ] 모의 거래와 실전 거래 계정을 혼동하지 않도록 주의하세요.
#
# ⚠️ 실전 거래 전 필수 확인사항:
# - [ ] DEMO 모드에서 최소 1개월간 충분히 검증 완료
# - [ ] 모든 리스크 관리 파라미터 점검 완료
# - [ ] 시스템 헬스체크 (GET /api/system/health) 정상 확인
# - [ ] 텔레그램 알림 정상 작동 확인
#
# 📚 참고: https://apiportal.koreainvestment.com
# ═══════════════════════════════════════════════════════════════════════════════
