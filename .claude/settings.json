{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m ruff check:*)",
      "Bash(python -m black --check:*)",
      "Bash(python -m black:*)",
      "Bash(python -m pytest:*)",
      "Bash(python scripts/check_bool_literals.py:*)",
      "Bash(python scripts/check_rbac_coverage.py:*)",
      "Bash(python scripts/check_doc_sync.py:*)",
      "Bash(python scripts/check_loguru_style.py:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch --show-current)",
      "Bash(git worktree list)",
      "Bash(git show:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git push origin main --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf *:*)",
      "Write(./CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Edit(./CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(./agent_docs/development-policies.md)",
      "Write(agent_docs/development-policies.md)",
      "Edit(./agent_docs/development-policies.md)",
      "Edit(agent_docs/development-policies.md)",
      "Write(./backend/config/settings.py)",
      "Write(backend/config/settings.py)",
      "Edit(./backend/config/settings.py)",
      "Edit(backend/config/settings.py)",
      "Write(./backend/core/utils/env.py)",
      "Write(backend/core/utils/env.py)",
      "Edit(./backend/core/utils/env.py)",
      "Edit(backend/core/utils/env.py)",
      "Write(./backend/core/utils/time.py)",
      "Write(backend/core/utils/time.py)",
      "Edit(./backend/core/utils/time.py)",
      "Edit(backend/core/utils/time.py)",
      "Write(./.env.example)",
      "Write(.env.example)",
      "Edit(./.env.example)",
      "Edit(.env.example)",
      "Write(./docs/archive/**)",
      "Edit(./docs/archive/**)"
    ]
  },
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "hooks": {}
}
